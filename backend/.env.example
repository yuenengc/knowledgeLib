# DeepSeek (OpenAI-compatible) settings
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# FastEmbed embedding model
HF_EMBED_MODEL=BAAI/bge-small-zh-v1.5
